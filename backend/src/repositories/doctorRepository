const pool = require('../config/database');

const findAll = async (specialtyId) => {
  let query = `
    SELECT d.id, d.name, s.name AS specialty
    FROM doctors d
    JOIN specialties s ON d.specialty_id = s.id
  `;
  const params = [];

  if (specialtyId) {
    query += ' WHERE d.specialty_id = $1';
    params.push(specialtyId);
  }

  const result = await pool.query(query, params);
  return result.rows;
};

const findById = async (id) => {
  const result = await pool.query(
    `SELECT d.id, d.name, s.name AS specialty
     FROM doctors d
     JOIN specialties s ON d.specialty_id = s.id
     WHERE d.id = $1`,
    [id]
  );
  return result.rows[0];
};

const findSchedules = async (doctorId) => {
  const result = await pool.query(
    'SELECT * FROM schedules WHERE doctor_id = $1',
    [doctorId]
  );
  return result.rows;
};

module.exports = { findAll, findById, findSchedules };